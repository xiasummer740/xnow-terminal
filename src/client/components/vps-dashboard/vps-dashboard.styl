.vps-dashboard-modal
  .ant-modal-body
    padding 12px 24px
  .vps-stats-bar
    padding 8px 0 12px
    display flex
    align-items center
    flex-wrap wrap
    gap 8px
  .vps-row-expired
    background rgba(255, 77, 79, 0.08)
    &:hover td
      background rgba(255, 77, 79, 0.15) !important
  .vps-row-expiring
    background rgba(250, 173, 20, 0.06)
    &:hover td
      background rgba(250, 173, 20, 0.12) !important
