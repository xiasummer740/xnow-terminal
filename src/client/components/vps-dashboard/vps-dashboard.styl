.vps-dashboard-modal
  .ant-modal-header
    background linear-gradient(135deg, #0a0e1a 0%, #1a1040 100%)
    border-bottom 1px solid rgba(0, 245, 255, 0.2)
  .ant-modal-body
    background #0a0e1a
    padding 16px 24px

.vps-dash-title
  color #e0e0e0
  font-size 16px

// 顶部统计条
.vps-stats-strip
  display flex
  gap 16px
  padding 12px 0
  margin-bottom 12px
  border-bottom 1px solid rgba(0, 245, 255, 0.1)

.stat-item
  text-align center
  min-width 60px
  padding 8px 16px
  border-radius 6px
  background rgba(255,255,255,0.03)
  border 1px solid rgba(255,255,255,0.06)
  &.total
    border-color rgba(0, 245, 255, 0.2)
    .stat-num
      color #00f5ff
  &.healthy
    border-color rgba(82, 196, 26, 0.2)
    .stat-num
      color #52c41a
  &.warning
    border-color rgba(250, 173, 20, 0.3)
    .stat-num
      color #faad14
  &.danger
    border-color rgba(255, 77, 79, 0.3)
    .stat-num
      color #ff4d4f

.stat-num
  font-size 24px
  font-weight bold
  font-family 'Maple Mono', monospace
  display block
  line-height 1.2

.stat-label
  font-size 11px
  color #888
  margin-top 2px
  display block

// 卡片网格
.vps-card-grid
  display grid
  grid-template-columns repeat(auto-fill, minmax(260px, 1fr))
  gap 12px
  max-height 460px
  overflow-y auto
  padding 4px 0

// 卡片
.vps-card
  background rgba(255,255,255,0.03)
  border 1px solid rgba(255,255,255,0.08)
  border-radius 8px
  padding 14px 16px
  transition all 0.3s ease
  position relative
  overflow hidden

  &::before
    content ''
    position absolute
    top 0
    left 0
    right 0
    height 2px
    border-radius 8px 8px 0 0

  &.normal::before
    background linear-gradient(90deg, #52c41a, #00f5ff)
  &.expiring::before
    background linear-gradient(90deg, #faad14, #ff4d4f)
    box-shadow 0 0 12px rgba(250, 173, 20, 0.15)
  &.expired::before
    background linear-gradient(90deg, #ff4d4f, #ff7875)
    box-shadow 0 0 12px rgba(255, 77, 79, 0.2)

  &:hover
    border-color rgba(0, 245, 255, 0.2)
    background rgba(255,255,255,0.05)
    transform translateY(-1px)

.vps-card-header
  display flex
  justify-content space-between
  align-items center
  margin-bottom 6px

.vps-region
  font-size 12px
  font-weight bold

.vps-card-link
  color #666
  cursor pointer
  font-size 14px
  &:hover
    color #00f5ff

.vps-card-name
  font-size 14px
  font-weight bold
  color #e0e0e0
  margin-bottom 8px
  white-space nowrap
  overflow hidden
  text-overflow ellipsis

.vps-card-expiry
  margin-bottom 8px

.vps-card-info
  display flex
  gap 12px
  flex-wrap wrap
  margin-bottom 6px
  font-size 12px
  color #aaa

.vps-info-item
  display flex
  align-items center
  gap 3px

.vps-card-recharge
  font-size 11px
  color #888
  margin-top 4px

.vps-no-expiry
  color #666
  font-size 12px

.vps-empty
  padding 40px 0
