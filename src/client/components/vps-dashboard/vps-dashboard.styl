.vps-dashboard-modal
  .ant-modal-content
    border-radius 8px
    overflow hidden
    background #141414
  .ant-modal-header
    background #141414
    border-bottom 1px solid #222
  .ant-modal-body
    background #141414
    padding 20px 24px
  .ant-tag
    font-size 11px

// 概览
.vps-overview
  display flex
  gap 32px
  padding 12px 0 16px
  border-bottom 1px solid #222
  margin-bottom 12px

.vps-overview-item
  text-align center
  .vps-overview-num
    font-size 28px
    font-weight 700
    font-family 'Maple Mono', monospace
    color #e0e0e0
    display block
    line-height 1.2
  .vps-overview-label
    font-size 11px
    color #888
  &.green .vps-overview-num
    color #52c41a
  &.orange .vps-overview-num
    color #faad14
  &.red .vps-overview-num
    color #ff4d4f

// 表格
.vps-table-wrap
  max-height 480px
  overflow-y auto

.vps-table
  width 100%
  border-collapse collapse
  thead th
    font-size 11px
    font-weight 500
    color #888
    text-align left
    padding 8px 12px
    border-bottom 1px solid #222
    background #141414
    position sticky
    top 0
    z-index 1
  tbody td
    padding 10px 12px
    border-bottom 1px solid #1a1a1a
    font-size 13px
    color #ccc
    vertical-align middle
  tbody tr
    transition background 0.15s
    &:hover
      background rgba(255,255,255,0.03)
    &.row-expired
      background rgba(255, 77, 79, 0.06)
      &:hover
        background rgba(255, 77, 79, 0.1)
    &.row-warning
      background rgba(250, 173, 20, 0.04)
      &:hover
        background rgba(250, 173, 20, 0.08)

.vps-name
  font-weight 600
  color #e8e8e8

.vps-host
  font-family monospace
  font-size 12px
  color #999

.vps-expiry-cell
  display flex
  align-items center

// XNOW 监控实时监控样式
.vps-monitor-quick-actions
  display flex
  gap 8px
  align-items center

.vps-monitor-card-hover
  transition all 0.2s ease
  &:hover
    border-color #1890ff
    transform translateY(-2px)
    box-shadow 0 4px 16px rgba(24,144,255,0.12)

// 监控表格暗色适配
.vps-dashboard-modal
  .ant-table
    background transparent !important
    color #ccc
  .ant-table-thead > tr > th
    background #141414 !important
    border-bottom 1px solid #222
    color #888
    font-size 11px
  .ant-table-tbody > tr > td
    border-bottom 1px solid #1a1a1a
    color #ccc
  .ant-table-tbody > tr:hover > td
    background rgba(255,255,255,0.02) !important
  .ant-table-placeholder:hover > td
    background transparent !important
  .ant-empty-description
    color #666
  .ant-segmented-item
    color #888
  .ant-segmented-item-selected
    background #1890ff
    color #fff
