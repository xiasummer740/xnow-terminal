.vps-dashboard-modal
  .ant-modal-content
    border-radius 8px
    overflow hidden
    background #141414
  .ant-modal-header
    background #141414
    border-bottom 1px solid #2a2a2a
  .ant-modal-body
    background #141414
    padding 16px 24px

.vps-dash-title
  color #e0e0e0
  font-size 15px

// 顶部统计条
.vps-stats-strip
  display flex
  gap 24px
  padding 10px 0
  margin-bottom 10px
  border-bottom 1px solid #2a2a2a

.stat-item
  text-align center
  .stat-num
    font-size 22px
    font-weight bold
    font-family 'Maple Mono', monospace
    &.c-total
      color #1890ff
    &.c-good
      color #52c41a
    &.c-warn
      color #faad14
    &.c-bad
      color #ff4d4f
  .stat-label
    font-size 11px
    color #888

// 卡片网格
.vps-card-grid
  display grid
  grid-template-columns repeat(auto-fill, minmax(240px, 1fr))
  gap 10px
  max-height 420px
  overflow-y auto

.vps-card
  background #1a1a1a
  border 1px solid #2a2a2a
  border-radius 6px
  padding 12px 14px
  transition border-color 0.2s

  &.expired
    border-color rgba(255, 77, 79, 0.3)
  &.expiring
    border-color rgba(250, 173, 20, 0.25)

  &:hover
    border-color #434343

.vps-card-header
  display flex
  justify-content space-between
  align-items center
  margin-bottom 6px

.vps-host
  font-size 11px
  color #888
  font-family monospace

.vps-card-link
  color #555
  cursor pointer
  font-size 13px
  &:hover
    color #1890ff

.vps-card-name
  font-size 13px
  font-weight 600
  color #e0e0e0
  margin-bottom 8px
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.vps-card-expiry
  margin-bottom 6px

.vps-card-info
  display flex
  gap 16px
  font-size 12px
  color #999

.vps-info-item
  display flex
  align-items center
  gap 3px

.vps-card-recharge
  font-size 11px
  color #777
  margin-top 4px

.vps-no-expiry
  color #555
  font-size 12px

.vps-empty
  padding 40px 0
