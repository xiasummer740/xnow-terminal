.quick-search-modal
  .ant-modal-content
    background #1a1a1a
    border-radius 8px
    border 1px solid #333
  .ant-modal-body
    padding 12px
  .ant-input-affix-wrapper
    background #1a1a1a
    border none
    box-shadow none
  .ant-input
    color #e0e0e0

.quick-search-list
  margin-top 8px
  max-height 400px
  overflow-y auto
  .ant-list-item
    padding 8px 12px
    border none
    border-bottom 1px solid #252525
    cursor pointer
    border-radius 4px
    &:hover
      background rgba(255,255,255,0.05)
    &:last-child
      border-bottom none

.qs-icon
  font-size 14px
  margin-right 10px
  color #888

.qs-content
  flex 1
  overflow hidden

.qs-label
  font-size 13px
  color #e0e0e0
  overflow hidden
  text-overflow ellipsis
  white-space nowrap

.qs-desc
  font-size 11px
  color #666
  margin-top 2px
